{
  "name": "diffscope-test-fixture",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "report": "npm run test:baseline && npm run test:diffs && npm run zip-report",
    "test:baseline": "npx playwright test --update-snapshots",
    "test:diffs": "GENERATE_DIFFS=true npx playwright test --reporter=html || true",
    "zip-report": "cd playwright-report && zip -r ../playwright-report.zip . && cd .."
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "serve": "^14.2.6"
  }
}
